# Copy this file to .env and fill with real values. .env is gitignored.
# All values that contain JSON must stay on a single line.

# ---- Model ----
NLI_MODEL=MoritzLaurer/multilingual-MiniLMv2-L6-mnli-xnli

# ---- Category keys (generic; the code never references the real domain) ----
CATEGORY_KEYS=["cat_a","cat_b","cat_c"]

# ---- Hypotheses per category (JSON array of full sentences) ----
HYPOTHESES_CAT_A=["hypothesis 1 for cat_a","hypothesis 2 for cat_a"]
HYPOTHESES_CAT_B=["hypothesis 1 for cat_b"]
HYPOTHESES_CAT_C=["hypothesis 1 for cat_c"]

# ---- Lexical patterns per category (JSON object) ----
# Optional fields per category: frases, emojis, hashtags, regex (single python regex string).
LEXICAL_CAT_A={"frases":["frase 1","frase 2"],"emojis":[],"hashtags":[],"regex":""}
LEXICAL_CAT_B={"frases":[]}
LEXICAL_CAT_C={"frases":[]}

# ---- Decision thresholds per category ----
THRESHOLDS={"cat_a":0.75,"cat_b":0.55,"cat_c":0.70}

# ---- Test cases (JSON array of {text, expected}). expected can be null. ----
TEST_CASES=[{"text":"sample positive text","expected":"cat_a"},{"text":"sample negative text","expected":null}]
